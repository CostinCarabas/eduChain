{
    "name": "edu-chain-nft: addIssuer / removeIssuer / isIssuer",
    "steps": [
        {
            "step": "setState",
            "accounts": {
                "address:owner": { "nonce": "1", "balance": "1000000000000000000" },
                "address:issuer1": { "nonce": "0", "balance": "0" }
            },
            "newAddresses": [
                {
                    "creatorAddress": "address:owner",
                    "creatorNonce": "1",
                    "newAddress": "sc:edu-chain-nft"
                }
            ]
        },
        {
            "step": "scDeploy",
            "id": "deploy",
            "tx": {
                "from": "address:owner",
                "contractCode": "mxsc:../output/edu-chain-nft.mxsc.json",
                "arguments": [],
                "gasLimit": "5,000,000",
                "gasPrice": "0"
            },
            "expect": { "status": "0", "gas": "*", "refund": "*" }
        },
        {
            "step": "scCall",
            "id": "addIssuer",
            "tx": {
                "from": "address:owner",
                "to": "sc:edu-chain-nft",
                "function": "addIssuer",
                "arguments": [ "address:issuer1" ],
                "gasLimit": "5,000,000",
                "gasPrice": "0"
            },
            "expect": { "status": "0", "gas": "*", "refund": "*" }
        },
        {
            "step": "scQuery",
            "id": "isIssuer-true",
            "tx": {
                "to": "sc:edu-chain-nft",
                "function": "isIssuer",
                "arguments": [ "address:issuer1" ]
            },
            "expect": {
                "out": [ "0x01" ],
                "status": "0"
            }
        },
        {
            "step": "scCall",
            "id": "removeIssuer",
            "tx": {
                "from": "address:owner",
                "to": "sc:edu-chain-nft",
                "function": "removeIssuer",
                "arguments": [ "address:issuer1" ],
                "gasLimit": "5,000,000",
                "gasPrice": "0"
            },
            "expect": { "status": "0", "gas": "*", "refund": "*" }
        },
        {
            "step": "scQuery",
            "id": "isIssuer-false",
            "tx": {
                "to": "sc:edu-chain-nft",
                "function": "isIssuer",
                "arguments": [ "address:issuer1" ]
            },
            "expect": {
                "out": [ "0x" ],
                "status": "0"
            }
        }
    ]
}
